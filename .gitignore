# Terraform state — never commit
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Actual vars with real project_id — use terraform.tfvars.example instead
terraform.tfvars

# Binary plan file — the JSON evidence in evidence/plan.json is what we commit
tfplan

# Provider cache and working directory
.terraform/
.terraform.lock.hcl

# OS / editor noise
.DS_Store
*.swp
*.swo

# Content drafts — this repo publishes code and evidence, not writing.
# Root-level markdown is blocked except README; drafts live outside the repo.
*draft*.md
/*.md
!/README.md
!/PORTFOLIO-CASE-STUDY.md

# Secrets and credentials — belt and suspenders, should never exist here
.env*
*.pem
*.key

# Archives — starter bundles and exports stay local
*.zip
